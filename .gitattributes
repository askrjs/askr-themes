# Auto detect text files and normalize line endings
* text=auto

# Source files
*.css text eol=lf
*.js text eol=lf
*.json text eol=lf
*.md text eol=lf

# Shell scripts
*.sh text eol=lf
*.bash text eol=lf

# Windows-specific scripts
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Binary assets
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.mov binary
*.mp4 binary
*.mp3 binary
*.gz binary
*.zip binary
*.7z binary

# Git metadata files
.gitattributes text eol=lf
.gitignore text eol=lf
.gitkeep text eol=lf
