{
  "compilerOptions": {
    "baseUrl": ".",
    "target": "ES2020",
    "lib": ["ES2020", "DOM"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "jsxImportSource": "@askrjs/askr",
    "ignoreDeprecations": "6.0",
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true
  },
  "include": [
    "src/components/**/*",
    "src/themes/**/*",
    "src/*.d.ts",
    "tests/**/*",
    "vite.config.ts",
    "vitest.config.ts"
  ],
  "exclude": ["src/default/**/*"]
}
