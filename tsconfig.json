{
  "compilerOptions": {
    "baseUrl": ".",
    "target": "ES2020",
    "lib": ["ES2020", "DOM"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "jsxImportSource": "@askrjs/askr",
    "ignoreDeprecations": "6.0",
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "paths": {
      "@askrjs/askr": ["../askr/dist/index.d.ts"],
      "@askrjs/askr/jsx-runtime": ["../askr/dist/jsx-runtime.d.ts"],
      "@askrjs/askr/jsx-dev-runtime": ["../askr/dist/jsx-dev-runtime.d.ts"],
      "@askrjs/askr/foundations": ["../askr/dist/foundations/index.d.ts"],
      "@askrjs/ui/foundations": ["../askr-ui/src/foundations/index.ts"]
    }
  },
  "include": [
    "src/components/**/*",
    "src/themes/**/*",
    "src/*.d.ts",
    "tests/**/*",
    "vite.config.ts",
    "vitest.config.ts"
  ],
  "exclude": ["src/default/**/*"]
}

