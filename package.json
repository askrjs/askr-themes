{
  "name": "@askrjs/askr-themes",
  "version": "0.0.1",
  "description": "Default theme tokens, styles, and themed layout wrappers for askr-ui.",
  "keywords": [
    "askr",
    "css",
    "design-tokens",
    "themes"
  ],
  "homepage": "https://github.com/askrjs/askr-themes#readme",
  "bugs": {
    "url": "https://github.com/askrjs/askr-themes/issues"
  },
  "license": "Apache-2.0",
  "author": {
    "name": "askrjs",
    "url": "https://github.com/askrjs"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/askrjs/askr-themes.git"
  },
  "files": [
    "dist",
    "src",
    "templates",
    "scripts/new-theme.js",
    "THEMING.md",
    "LICENSE"
  ],
  "type": "module",
  "sideEffects": [
    "**/*.css"
  ],
  "exports": {
    ".": "./src/index.css",
    "./default": "./src/themes/default/index.css",
    "./components": {
      "types": "./dist/components/index.d.ts",
      "import": "./dist/components/index.js"
    },
    "./default/card.css": "./src/themes/default/styles/card.css",
    "./default/tokens.css": "./src/themes/default/tokens.css",
    "./default/accordion.css": "./src/themes/default/styles/accordion.css",
    "./default/alert-dialog.css": "./src/themes/default/styles/alert-dialog.css",
    "./default/app-shell.css": "./src/themes/default/styles/app-shell.css",
    "./default/avatar.css": "./src/themes/default/styles/avatar.css",
    "./default/badge.css": "./src/themes/default/styles/badge.css",
    "./default/breadcrumb.css": "./src/themes/default/styles/breadcrumb.css",
    "./default/button.css": "./src/themes/default/styles/button.css",
    "./default/checkbox.css": "./src/themes/default/styles/checkbox.css",
    "./default/collapsible.css": "./src/themes/default/styles/collapsible.css",
    "./default/coverage.css": "./src/themes/default/styles/coverage.css",
    "./default/data-table.css": "./src/themes/default/styles/data-table.css",
    "./default/dashboard-layout.css": "./src/themes/default/styles/dashboard-layout.css",
    "./default/dialog.css": "./src/themes/default/styles/dialog.css",
    "./default/docs-layout.css": "./src/themes/default/styles/docs-layout.css",
    "./default/dropdown-menu.css": "./src/themes/default/styles/dropdown-menu.css",
    "./default/field.css": "./src/themes/default/styles/field.css",
    "./default/input.css": "./src/themes/default/styles/input.css",
    "./default/label.css": "./src/themes/default/styles/label.css",
    "./default/menu.css": "./src/themes/default/styles/menu.css",
    "./default/menubar.css": "./src/themes/default/styles/menubar.css",
    "./default/navbar.css": "./src/themes/default/styles/navbar.css",
    "./default/navigation-menu.css": "./src/themes/default/styles/navigation-menu.css",
    "./default/pagination.css": "./src/themes/default/styles/pagination.css",
    "./default/popover.css": "./src/themes/default/styles/popover.css",
    "./default/progress.css": "./src/themes/default/styles/progress.css",
    "./default/progress-circle.css": "./src/themes/default/styles/progress-circle.css",
    "./default/product-shell.css": "./src/themes/default/styles/product-shell.css",
    "./default/radio-group.css": "./src/themes/default/styles/radio-group.css",
    "./default/responsive-layout.css": "./src/themes/default/styles/responsive-layout.css",
    "./default/select.css": "./src/themes/default/styles/select.css",
    "./default/separator.css": "./src/themes/default/styles/separator.css",
    "./default/sidebar.css": "./src/themes/default/styles/sidebar.css",
    "./default/skeleton.css": "./src/themes/default/styles/skeleton.css",
    "./default/slider.css": "./src/themes/default/styles/slider.css",
    "./default/spinner.css": "./src/themes/default/styles/spinner.css",
    "./default/switch.css": "./src/themes/default/styles/switch.css",
    "./default/tabs.css": "./src/themes/default/styles/tabs.css",
    "./default/textarea.css": "./src/themes/default/styles/textarea.css",
    "./default/toast.css": "./src/themes/default/styles/toast.css",
    "./default/toggle.css": "./src/themes/default/styles/toggle.css",
    "./default/toggle-group.css": "./src/themes/default/styles/toggle-group.css",
    "./default/tooltip.css": "./src/themes/default/styles/tooltip.css",
    "./templates/*": "./templates/*"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "new:theme": "node ./scripts/new-theme.js",
    "verify:token-contract": "node ./scripts/verify-token-contract.js",
    "verify:responsive": "node ./scripts/verify-responsive-theme.js",
    "verify:slots": "node ./scripts/verify-slot-coverage.js",
    "test": "npm run test:unit",
    "test:unit": "vp test run -c vitest.config.ts",
    "fmt": "vp fmt .",
    "lint": "vp fmt --check .",
    "build:types": "tsc -p tsconfig.pack.json --emitDeclarationOnly --outDir dist",
    "build": "vp build && npm run build:types && npm run verify:token-contract && npm run verify:responsive && npm run verify:slots"
  },
  "devDependencies": {
    "@askrjs/askr": "file:../askr",
    "@askrjs/askr-ui": "file:../askr-ui",
    "@types/node": "^25.6.0",
    "typescript": "^6.0.3",
    "vite-plus": "^0.1.19"
  },
  "peerDependencies": {
    "@askrjs/askr": "0.0.1",
    "@askrjs/askr-ui": "0.0.1"
  },
  "engines": {
    "node": ">=18"
  }
}
