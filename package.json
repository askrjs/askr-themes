{
  "name": "@askrjs/themes",
  "version": "0.0.8",
  "description": "Default theme tokens, styles, and themed layout wrappers for Askr apps.",
  "keywords": [
    "askr",
    "css",
    "design-tokens",
    "themes"
  ],
  "homepage": "https://github.com/askrjs/askr-themes#readme",
  "bugs": {
    "url": "https://github.com/askrjs/askr-themes/issues"
  },
  "license": "Apache-2.0",
  "author": {
    "name": "askrjs",
    "url": "https://github.com/askrjs"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/askrjs/askr-themes.git"
  },
  "files": [
    "dist",
    "src",
    "templates",
    "scripts/new-theme.js",
    "THEMING.md",
    "LICENSE"
  ],
  "type": "module",
  "sideEffects": [
    "**/*.css"
  ],
  "exports": {
    ".": "./src/index.css",
    "./default": "./src/themes/default/index.css",
    "./presets": "./src/themes/presets/index.css",
    "./cat-presets": "./src/themes/presets/index.css",
    "./theme": {
      "types": "./dist/theme.d.ts",
      "import": "./dist/theme.js"
    },
    "./layouts": {
      "types": "./dist/layouts.d.ts",
      "import": "./dist/layouts.js"
    },
    "./controls": {
      "types": "./dist/controls.d.ts",
      "import": "./dist/controls.js"
    },
    "./surfaces": {
      "types": "./dist/surfaces.d.ts",
      "import": "./dist/surfaces.js"
    },
    "./feedback": {
      "types": "./dist/feedback.d.ts",
      "import": "./dist/feedback.js"
    },
    "./shells": {
      "types": "./dist/shells.d.ts",
      "import": "./dist/shells.js"
    },
    "./navs": {
      "types": "./dist/navs.d.ts",
      "import": "./dist/navs.js"
    },
    "./overlays": {
      "types": "./dist/overlays.d.ts",
      "import": "./dist/overlays.js"
    },
    "./default/card.css": "./src/themes/default/styles/display/card.css",
    "./default/tokens.css": "./src/themes/default/tokens.css",
    "./default/accordion.css": "./src/themes/default/styles/disclosure/accordion.css",
    "./default/alert-dialog.css": "./src/themes/default/styles/overlays/alert-dialog.css",
    "./default/avatar.css": "./src/themes/default/styles/display/avatar.css",
    "./default/badge.css": "./src/themes/default/styles/display/badge.css",
    "./default/breadcrumb.css": "./src/themes/default/styles/navigation/breadcrumb.css",
    "./default/button.css": "./src/themes/default/styles/actions/button.css",
    "./default/button-group.css": "./src/themes/default/styles/actions/button-group.css",
    "./default/nav.css": "./src/themes/default/styles/navigation/nav.css",
    "./default/block.css": "./src/themes/default/styles/layout/block.css",
    "./default/checkbox.css": "./src/themes/default/styles/forms/checkbox.css",
    "./default/collapsible.css": "./src/themes/default/styles/disclosure/collapsible.css",
    "./default/alert.css": "./src/themes/default/styles/display/alert.css",
    "./default/coverage.css": "./src/themes/default/styles/display/coverage.css",
    "./default/table.css": "./src/themes/default/styles/display/table.css",
    "./default/dialog.css": "./src/themes/default/styles/overlays/dialog.css",
    "./default/dropdown.css": "./src/themes/default/styles/overlays/dropdown.css",
    "./default/input.css": "./src/themes/default/styles/forms/input.css",
    "./default/input-group.css": "./src/themes/default/styles/forms/input-group.css",
    "./default/field.css": "./src/themes/default/styles/forms/field.css",
    "./default/label.css": "./src/themes/default/styles/forms/label.css",
    "./default/list-group.css": "./src/themes/default/styles/display/list-group.css",
    "./default/virtual-list.css": "./src/themes/default/styles/display/virtual-list.css",
    "./default/menu.css": "./src/themes/default/styles/navigation/menu.css",
    "./default/menubar.css": "./src/themes/default/styles/navigation/menubar.css",
    "./default/pagination.css": "./src/themes/default/styles/navigation/pagination.css",
    "./default/navbar.css": "./src/themes/default/styles/shell/navbar.css",
    "./default/patterns.css": "./src/themes/default/styles/layout/patterns.css",
    "./default/popover.css": "./src/themes/default/styles/overlays/popover.css",
    "./default/progress.css": "./src/themes/default/styles/display/progress.css",
    "./default/progress-circle.css": "./src/themes/default/styles/display/progress-circle.css",
    "./default/radio-group.css": "./src/themes/default/styles/forms/radio-group.css",
    "./default/responsive-layout.css": "./src/themes/default/styles/layout/responsive-layout.css",
    "./default/select.css": "./src/themes/default/styles/forms/select.css",
    "./default/separator.css": "./src/themes/default/styles/display/separator.css",
    "./default/skeleton.css": "./src/themes/default/styles/display/skeleton.css",
    "./default/slider.css": "./src/themes/default/styles/forms/slider.css",
    "./default/spinner.css": "./src/themes/default/styles/display/spinner.css",
    "./default/switch.css": "./src/themes/default/styles/forms/switch.css",
    "./default/textarea.css": "./src/themes/default/styles/forms/textarea.css",
    "./default/toast.css": "./src/themes/default/styles/overlays/toast.css",
    "./default/toggle.css": "./src/themes/default/styles/actions/toggle.css",
    "./default/toggle-group.css": "./src/themes/default/styles/actions/toggle-group.css",
    "./default/tooltip.css": "./src/themes/default/styles/overlays/tooltip.css",
    "./default/virtual-table.css": "./src/themes/default/styles/display/virtual-table.css",
    "./templates/*": "./templates/*"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "new:theme": "node ./scripts/new-theme.js",
    "clean": "npx --yes rimraf dist node_modules",
    "bench": "npm run bench:tier1 && npm run bench:tier2 && npm run bench:tier3 && npm run bench:tier4",
    "bench:tier1": "cross-env NODE_ENV=production vp test bench --run --reporter=default --config vitest.bench.tier1.config.ts",
    "bench:tier2": "cross-env NODE_ENV=production vp test bench --run --reporter=default --config vitest.bench.tier2.config.ts",
    "bench:tier3": "cross-env NODE_ENV=production vp test bench --run --reporter=default --config vitest.bench.tier3.config.ts",
    "bench:tier4": "cross-env NODE_ENV=production vp test bench --run --reporter=default --config vitest.bench.tier4.config.ts --mode production",
    "test": "npm run test:unit && npm run test:checks && npm run test:jsdom && npm run test:browser",
    "test:unit": "vp test run -c vitest.test.unit.config.ts",
    "test:jsdom": "cross-env NODE_ENV=production vp test run -c vitest.test.jsdom.config.ts",
    "test:browser": "vp test run -c vitest.test.browser.config.ts --mode production",
    "fmt": "vp fmt .",
    "lint": "vp lint .",
    "build": "vp pack",
    "prepublishOnly": "npm run build",
    "test:checks": "vp test run -c vitest.test.checks.config.ts"
  },
  "devDependencies": {
    "@askrjs/askr": ">=0.0.1 <0.1.0",
    "@askrjs/ui": ">=0.0.1 <0.1.0",
    "@askrjs/vite": ">=0.0.1 <0.1.0",
    "@tsdown/css": "0.22.3",
    "@types/node": "^26.0.0",
    "@vitest/browser-playwright": "^4.1.9",
    "cross-env": "^10.1.0",
    "jsdom": "^29.1.1",
    "playwright": "^1.61.0",
    "typescript": "^6.0.3",
    "vite-plus": "^0.2.1"
  },
  "peerDependencies": {
    "@askrjs/askr": ">=0.0.1 <0.1.0",
    "@askrjs/ui": ">=0.0.10 <0.1.0"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "npm@11.17.0"
}
