{
  "name": "@askrjs/themes",
  "version": "0.0.9",
  "description": "Default theme tokens, styles, and component presets for Askr apps.",
  "keywords": [
    "askr",
    "css",
    "design-tokens",
    "themes"
  ],
  "homepage": "https://github.com/askrjs/askr-themes#readme",
  "bugs": {
    "url": "https://github.com/askrjs/askr-themes/issues"
  },
  "license": "Apache-2.0",
  "author": {
    "name": "askrjs",
    "url": "https://github.com/askrjs"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/askrjs/askr-themes.git"
  },
  "files": [
    "dist",
    "src",
    "templates",
    "scripts/new-theme.js",
    "THEMING.md",
    "LICENSE"
  ],
  "type": "module",
  "sideEffects": [
    "**/*.css"
  ],
  "exports": {
    ".": "./src/index.css",
    "./default": "./src/themes/default/index.css",
    "./presets": "./src/themes/presets/index.css",
    "./theme": {
      "types": "./dist/theme.d.ts",
      "import": "./dist/theme.js"
    },
    "./core": {
      "types": "./dist/core.d.ts",
      "import": "./dist/core.js"
    },
    "./controls": {
      "types": "./dist/controls.d.ts",
      "import": "./dist/controls.js"
    },
    "./surfaces": {
      "types": "./dist/surfaces.d.ts",
      "import": "./dist/surfaces.js"
    },
    "./navs": {
      "types": "./dist/navs.d.ts",
      "import": "./dist/navs.js"
    },
    "./overlays": {
      "types": "./dist/overlays.d.ts",
      "import": "./dist/overlays.js"
    },
    "./default/tokens.css": "./src/themes/default/tokens.css",
    "./templates/*": "./templates/*"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "new:theme": "node ./scripts/new-theme.js",
    "clean": "npx --yes rimraf dist node_modules",
    "bench": "npm run bench:tier1 && npm run bench:tier2 && npm run bench:tier3 && npm run bench:tier4",
    "bench:tier1": "cross-env NODE_ENV=production vp test bench --run --reporter=default --config vitest.bench.tier1.config.ts",
    "bench:tier2": "cross-env NODE_ENV=production vp test bench --run --reporter=default --config vitest.bench.tier2.config.ts",
    "bench:tier3": "cross-env NODE_ENV=production vp test bench --run --reporter=default --config vitest.bench.tier3.config.ts",
    "bench:tier4": "cross-env NODE_ENV=production vp test bench --run --reporter=default --config vitest.bench.tier4.config.ts --mode production",
    "test": "npm run test:unit && npm run test:checks && npm run test:jsdom && npm run test:browser",
    "test:unit": "vp test run -c vitest.test.unit.config.ts",
    "test:jsdom": "cross-env NODE_ENV=production vp test run -c vitest.test.jsdom.config.ts",
    "test:browser": "vp test run -c vitest.test.browser.config.ts --mode production",
    "fmt": "vp fmt .",
    "lint": "vp lint .",
    "build": "vp pack",
    "prepublishOnly": "npm run build",
    "test:checks": "vp test run -c vitest.test.checks.config.ts"
  },
  "devDependencies": {
    "@askrjs/askr": ">=0.0.1 <0.1.0",
    "@askrjs/ui": ">=0.0.1 <0.1.0",
    "@askrjs/vite": ">=0.0.1 <0.1.0",
    "@tsdown/css": "0.22.3",
    "@types/node": "^26.0.0",
    "@vitest/browser-playwright": "^4.1.9",
    "cross-env": "^10.1.0",
    "jsdom": "^29.1.1",
    "playwright": "^1.61.0",
    "typescript": "^6.0.3",
    "vite-plus": "^0.2.1"
  },
  "peerDependencies": {
    "@askrjs/askr": ">=0.0.1 <0.1.0",
    "@askrjs/ui": ">=0.0.10 <0.1.0"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "npm@11.17.0"
}
